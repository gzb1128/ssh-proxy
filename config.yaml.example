# Remote server configuration
remote_server:
  host: "your-server-ip"      # Remote server IP, all services listen on this IP
  ssh_name: "your-ssh-user"   # SSH connection name for ssh command

# Environment variables (optional)
# Use {{ env.VAR_NAME }} to reference in config
env:
  MY_SERVER_IP: "192.168.1.100"
  DB_HOST: "10.0.0.5"
  DOMAIN_SUFFIX: example.local

# Note:
# By default, HTTP proxy mode is enabled, which automatically sets the Host header
# to the remote server's domain. This allows direct access via localhost:local_port
# without modifying /etc/hosts.
# Use --no-http-proxy flag to disable HTTP proxy mode and use direct SSH tunnel.

# Service definitions
services:
  example-service:
    remote_port: 8080
    local_port: 8080          # Optional, defaults to remote_port

  another-service:
    remote_port: 3000
    # local_port not specified, will use 3000

  database:
    remote_port: 3306
    local_port: 13306         # Use different local port to avoid conflicts

  # Custom host, overrides remote_server.host
  custom-host-service:
    remote_port: 9000
    host: "custom.server.ip"  # Optional, will ignore remote_server.host

  # Use environment variables defined in env section
  env-example-service:
    remote_port: 8080
    host: "{{ env.MY_SERVER_IP }}"  # Reference env variable

  # Host only, remote_port defaults to 80
  host-only-service:
    host: "server.{{ env.DOMAIN_SUFFIX }}"

# Optional settings
options:
  startup_delay: 0.5          # Delay between starting each proxy (seconds)
